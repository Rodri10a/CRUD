<%- include('../partials/header') %>

<h1>Tecnologias de Programacion</h1>
<p>Vota por las tecnologias que mas te gustan</p>

<% topics.forEach(topic => { %>
  <div class="card">
    <div class="card-header">
      <h2><a href="/topics/<%= topic.id %>"><%= topic.title %></a></h2>
      <div class="card-actions">
        <a href="/topics/<%= topic.id %>/edit" class="btn btn-edit">Editar</a>
        <form action="/topics/<%= topic.id %>/delete" method="POST" style="display:inline">
          <button type="submit" class="btn btn-delete">Eliminar</button>
        </form>
      </div>
    </div>
    <p><%= topic.description %></p>
    <div class="vote-section">
      <button class="btn btn-vote vote-topic-btn" data-id="<%= topic.id %>">Votar</button>
      <span id="votes-<%= topic.id %>" class="vote-count"><%= topic.votes %> votos</span>
    </div>
  </div>
<% }) %>

<%- include('../partials/footer') %>
