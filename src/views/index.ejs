<%- include('partials/header') %>

<h1>Tecnologias de Programacion</h1>
<p>Vota por las tecnologias que mas te gustan</p>

<!-- Boton para mostrar formulario de crear -->
<button class="btn btn-primary" onclick="toggleForm('create-form')">+ Nuevo Topic</button>

<!-- Formulario crear (oculto por defecto) -->
<div id="create-form" class="form-container" style="display:none; margin-top:1rem;">
  <h2>Nuevo Topic</h2>
  <form action="/topics" method="POST" class="form">
    <div class="form-group">
      <label>Titulo</label>
      <input type="text" name="title" placeholder="Ej: JavaScript" required>
    </div>
    <div class="form-group">
      <label>Descripcion</label>
      <textarea name="description" placeholder="Describe esta tecnologia..." required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Crear Topic</button>
    <button type="button" class="btn" onclick="toggleForm('create-form')">Cancelar</button>
  </form>
</div>

<!-- Lista de topics -->
<% topics.forEach(topic => { %>
  <div class="card">
    <div class="card-header">
      <h2><a href="#" onclick="toggleForm('detail-<%= topic.id %>'); return false;"><%= topic.title %></a></h2>
      <div class="card-actions">
        <button class="btn btn-edit" onclick="toggleForm('edit-<%= topic.id %>')">Editar</button>
        <form action="/topics/<%= topic.id %>/delete" method="POST" style="display:inline">
          <button type="submit" class="btn btn-delete">Eliminar</button>
        </form>
      </div>
    </div>
    <p><%= topic.description %></p>
    <div class="vote-section">
      <button class="btn btn-vote vote-topic-btn" data-id="<%= topic.id %>">Votar</button>
      <span id="votes-<%= topic.id %>" class="vote-count"><%= topic.votes %> votos</span>
    </div>

    <!-- Formulario editar (oculto) -->
    <div id="edit-<%= topic.id %>" class="form-container" style="display:none; margin-top:1rem;">
      <h3>Editar Topic</h3>
      <form action="/topics/<%= topic.id %>/update" method="POST" class="form">
        <div class="form-group">
          <label>Titulo</label>
          <input type="text" name="title" value="<%= topic.title %>" required>
        </div>
        <div class="form-group">
          <label>Descripcion</label>
          <textarea name="description" required><%= topic.description %></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Guardar</button>
        <button type="button" class="btn" onclick="toggleForm('edit-<%= topic.id %>')">Cancelar</button>
      </form>
    </div>

    <!-- Detalle: links del topic (oculto) -->
    <div id="detail-<%= topic.id %>" style="display:none; margin-top:1rem;">
      <hr>
      <h3>Agregar recurso</h3>
      <form action="/topics/<%= topic.id %>/links" method="POST" class="form" style="display:flex; gap:0.5rem; align-items:center;">
        <input type="text" name="title" placeholder="Nombre del recurso" required>
        <input type="url" name="url" placeholder="https://..." required>
        <button type="submit" class="btn btn-primary">Agregar</button>
      </form>

      <h3 style="margin-top:1rem;">Recursos (<%= topic.links.length %>)</h3>
      <% topic.links.forEach(link => { %>
        <div class="link-card">
          <div class="link-info">
            <a href="<%= link.url %>" target="_blank"><%= link.title %></a>
          </div>
          <div class="link-actions">
            <button class="btn btn-vote vote-link-btn" data-topic-id="<%= topic.id %>" data-link-id="<%= link.id %>">Votar</button>
            <span id="link-votes-<%= link.id %>" class="vote-count"><%= link.votes %> votos</span>
            <form action="/topics/<%= topic.id %>/links/<%= link.id %>/update" method="POST" style="display:inline">
              <input type="text" name="title" value="<%= link.title %>" required>
              <input type="url" name="url" value="<%= link.url %>" required>
              <button type="submit" class="btn btn-edit">Actualizar</button>
            </form>
            <form action="/topics/<%= topic.id %>/links/<%= link.id %>/delete" method="POST" style="display:inline">
              <button type="submit" class="btn btn-delete">Eliminar</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% }) %>

<%- include('partials/footer') %>
