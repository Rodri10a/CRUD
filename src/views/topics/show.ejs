<%- include('../partials/header') %>

<div class="topic-detail">
  <a href="/" class="btn">← Volver</a>

  <h1><%= topic.title %></h1>
  <p><%= topic.description %></p>

  <div class="vote-section">
    <button class="btn btn-vote vote-topic-btn" data-id="<%= topic.id %>">Votar topic</button>
    <span id="votes-<%= topic.id %>" class="vote-count"><%= topic.votes %> votos</span>
  </div>

  <hr>

  <h2>Agregar recurso</h2>
  <form action="/topics/<%= topic.id %>/links" method="POST" class="form">
    <input type="text" name="title" placeholder="Nombre del recurso" required>
    <input type="url" name="url" placeholder="https://..." required>
    <button type="submit" class="btn btn-primary">Agregar link</button>
  </form>

  <hr>

  <h2>Recursos (<%= topic.links.length %>)</h2>

  <% topic.links.forEach(link => { %>
    <div class="link-card">
      <div class="link-info">
        <a href="<%= link.url %>" target="_blank"><%= link.title %></a>
      </div>
      <div class="link-actions">
        <button class="btn btn-vote vote-link-btn"
          data-topic-id="<%= topic.id %>"
          data-link-id="<%= link.id %>">
          Votar
        </button>
        <span id="link-votes-<%= link.id %>" class="vote-count"><%= link.votes %> votos</span>
        <form action="/topics/<%= topic.id %>/links/<%= link.id %>/update" method="POST" style="display:inline">
          <input type="text" name="title" value="<%= link.title %>" required>
          <input type="url" name="url" value="<%= link.url %>" required>
          <button type="submit" class="btn btn-edit">Actualizar</button>
        </form>
        <form action="/topics/<%= topic.id %>/links/<%= link.id %>/delete" method="POST" style="display:inline">
          <button type="submit" class="btn btn-delete">Eliminar</button>
        </form>
      </div>
    </div>
  <% }) %>
</div>

<%- include('../partials/footer') %>
